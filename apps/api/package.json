{
    "name": "@saas/api",
    "version": "1.0.0",
    "scripts": {
        "dev": "pnpm env:load tsx watch --include ./src src/http/server.ts",
        "env:load": "dotenv -e ../../.env --",
        "db:migrate": "pnpm env:load prisma migrate dev",
        "db:generate": "pnpm env:load prisma generate",
        "db:studio": "pnpm env:load prisma studio"
    },
    "dependencies": {
        "@fastify/cors": "^11.2.0",
        "@fastify/jwt": "^10.0.0",
        "@fastify/swagger": "^9.7.0",
        "@fastify/swagger-ui": "^5.2.6",
        "@prisma/adapter-pg": "^7.7.0",
        "@prisma/client": "^7.7.0",
        "@saas/auth": "workspace:*",
        "@saas/env": "workspace:*",
        "bcryptjs": "^3.0.3",
        "fastify": "^5.8.5",
        "fastify-plugin": "^5.1.0",
        "fastify-type-provider-zod": "^6.1.0",
        "pg": "^8.20.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@faker-js/faker": "^10.4.0",
        "@saas/eslint-config": "workspace:*",
        "@saas/prettier": "workspace:*",
        "@saas/ts-config": "workspace:*",
        "@types/node": "^25.6.0",
        "dotenv-cli": "^11.0.0",
        "prisma": "^7.7.0",
        "tsx": "^4.21.0"
    },
    "prettier": "@saas/prettier",
    "eslintConfig": {
        "extends": "@saas/eslint-config/node.cjs"
    }
